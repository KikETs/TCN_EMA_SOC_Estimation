__pycache__/
*.py[cod]
.ipynb_checkpoints/
.pytest_cache/

# Raw CALCE files are not redistributed.
Data/raw_dynamic/*
!Data/raw_dynamic/README.md
Data/raw_reference/*
!Data/raw_reference/README.md

# Driving-profile processed records are generated locally from raw CALCE files.
Data/processed/*
!Data/processed/README.md

# Full prediction dumps and large/intermediate training outputs are excluded.
Data/predictions/**/*.csv.gz
**/checkpoints/
*.ckpt
*.pt
*.pth
*.pkl
*.joblib

# Large camera-ready rasters are generated locally by the figure scripts.
*.tif
*.tiff
